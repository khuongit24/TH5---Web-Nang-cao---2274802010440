<%- include('partials/header') %>

<div class="row my-4">
    <div class="col-12">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">Giỏ hàng</li>
            </ol>
        </nav>
        <h2 class="mb-4">Giỏ hàng của bạn</h2>

        <% if (cartItems && cartItems.length > 0) { %>
            <div class="table-responsive shadow-sm bg-white rounded">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" width="10%">Hình ảnh</th>
                            <th scope="col" width="40%">Sản phẩm</th>
                            <th scope="col" width="15%">Đơn giá</th>
                            <th scope="col" width="15%">Số lượng</th>
                            <th scope="col" width="20%">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% cartItems.forEach(function(item) { %>
                            <tr>
                                <td>
                                    <img src="<%= item.imageUrl %>" alt="<%= item.name %>" class="img-fluid rounded" style="max-height: 60px;">
                                </td>
                                <td>
                                    <h6 class="mb-0"><%= item.name %></h6>
                                </td>
                                <td><%= item.price.toLocaleString('vi-VN') %> đ</td>
                                <td>
                                    <span class="badge bg-secondary px-3 py-2"><%= item.quantity %></span>
                                </td>
                                <td class="fw-bold">
                                    <%= (item.price * item.quantity).toLocaleString('vi-VN') %> đ
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                    <tfoot class="table-group-divider">
                        <tr>
                            <td colspan="4" class="text-end fw-bold fs-5">Tổng cộng:</td>
                            <td class="text-danger fw-bold fs-5"><%= total.toLocaleString('vi-VN') %> đ</td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a href="/" class="btn btn-outline-secondary">
                    &larr; Tiếp tục mua sắm
                </a>
                <div>
                    <form action="/cart/clear" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger me-2">Xóa giỏ hàng</button>
                    </form>
                    <button class="btn btn-success">Thanh toán ngay</button>
                </div>
            </div>
        <% } else { %>
            <div class="text-center py-5 bg-white shadow-sm rounded">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-cart-x text-muted" viewBox="0 0 16 16">
                        <path d="M7.354 5.646a.5.5 0 1 0-.708.708L7.793 7.5 6.646 8.646a.5.5 0 1 0 .708.708L8.5 8.207l1.146 1.147a.5.5 0 0 0 .708-.708L9.207 7.5l1.147-1.146a.5.5 0 0 0-.708-.708L8.5 6.793 7.354 5.646z"/>
                        <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1H.5zm3.915 10L3.102 4h10.796l-1.313 7h-8.17zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                    </svg>
                </div>
                <h4 class="text-muted mb-4">Giỏ hàng của bạn đang trống</h4>
                <a href="/" class="btn btn-primary">Khám phá sản phẩm ngay</a>
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/footer') %>
