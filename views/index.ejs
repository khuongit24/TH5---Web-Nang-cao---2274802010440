<%- include('partials/header') %>

<div class="row mb-4">
    <div class="col-12 text-center">
        <h2>Danh sách sản phẩm</h2>
        <p class="text-muted">Khám phá các sản phẩm tuyệt vời của chúng tôi</p>
    </div>
</div>

<div class="row">
    <% if (products && products.length > 0) { %>
        <% products.forEach(function(product) { %>
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="<%= product.imageUrl %>" class="card-img-top" alt="<%= product.name %>" style="height: 200px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title"><%= product.name %></h5>
                        <p class="card-text text-danger fw-bold"><%= product.price.toLocaleString('vi-VN') %> VNĐ</p>
                        <p class="card-text text-truncate"><%= product.description %></p>
                        <div class="mt-auto d-flex justify-content-between">
                            <a href="/product/<%= product._id %>" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>
                            <form action="/cart/add/<%= product._id %>" method="POST" class="d-inline">
                                <button type="submit" class="btn btn-primary btn-sm">Thêm vào giỏ</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <div class="col-12 text-center py-5">
            <h4 class="text-muted">Chưa có sản phẩm nào.</h4>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>
