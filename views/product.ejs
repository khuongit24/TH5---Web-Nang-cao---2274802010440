<%- include('partials/header') %>

<div class="row justify-content-center my-5">
    <div class="col-md-8">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">Chi tiết sản phẩm</li>
            </ol>
        </nav>
        
        <div class="card shadow">
            <div class="row g-0">
                <div class="col-md-5">
                    <img src="<%= product.imageUrl %>" class="img-fluid rounded-start h-100" alt="<%= product.name %>" style="object-fit: cover; min-height: 300px;">
                </div>
                <div class="col-md-7">
                    <div class="card-body d-flex flex-column h-100">
                        <h2 class="card-title mb-3"><%= product.name %></h2>
                        <h4 class="text-danger fw-bold mb-4"><%= product.price.toLocaleString('vi-VN') %> VNĐ</h4>
                        
                        <h5 class="mb-2">Mô tả sản phẩm:</h5>
                        <p class="card-text text-muted mb-4" style="line-height: 1.6;">
                            <%= product.description %>
                        </p>
                        
                        <div class="mt-auto pt-3 border-top">
                            <form action="/cart/add/<%= product._id %>" method="POST">
                                <button type="submit" class="btn btn-primary btn-lg w-100">
                                    Thêm vào giỏ hàng
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
